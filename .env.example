# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# API Authentication
API_BEARER_TOKEN=your-secret-token-min-32-chars-long-here

# Dashboard Login
DASHBOARD_USER=admin
DASHBOARD_PASS=your-password-here

# Redis
REDIS_URL=redis://localhost:6379

# Paths (defaults work for Docker)
PROJECTS_DIR=./projects
AGENTS_DIR=./agents
REPOS_DIR=./repos
REPORTS_DIR=./reports

# Claude Code CLI binary path
CLAUDE_BIN=claude

# Discord (optional global fallback)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Git tokens (referenced by project YAML tokenEnvVar)
# GITHUB_TOKEN_MYORG=ghp_xxxxxxxxxxxx
# BITBUCKET_TOKEN_MYORG=xxxxxxxxxxxxxxxx

# Docker volume paths (for docker-compose)
# CLAUDE_CONFIG_DIR=~/.claude
# SSH_KEY_DIR=~/.ssh
